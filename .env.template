# 环境变量模板
# 复制此文件为 local.env 或 prod.env 并填入实际值

# 运行环境
NODE_ENV=development

# 服务器端口
PORT=3002

# MCP 服务地址
MCP_SERVER_URL=http://localhost:3001

# SiliconFlow AI API 配置
# 获取 API Key: https://siliconflow.cn/
SILICONFLOW_API_KEY=your_api_key_here

# 访问密码（用于保护 API）
ACCESS_PASSWORD=your_strong_password_here

# 默认用户ID（本地调试用）
DEFAULT_USER_ID=demo_user
DEFAULT_USER_NAME=演示用户

# 是否启用模拟邮件功能（本地开发用）
ENABLE_MOCK_EMAIL=true
