{
  "manifest_version": 2,
  "name": "AI 邮件助手",
  "version": "2.0.0",
  "description": "AI 驱动的邮件助手，可在侧边栏与 AI 讨论邮件内容",
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-mail-assistant@koudai.xin",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "messagesRead",
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "message_display_action": {
    "default_title": "AI 邮件助手",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-32.png",
    "128": "icons/icon-80.png"
  },
  "sidebar_action": {
    "default_title": "AI 邮件助手",
    "default_panel": "sidebar.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-32.png"
    },
    "open_at_install": true
  }
}