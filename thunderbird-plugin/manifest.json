{
  "manifest_version": 2,
  "name": "Chat Helper",
  "version": "1.0.9",
  "description": "A chat helper for Thunderbird - opens a chat window",
  "browser_specific_settings": {
    "gecko": {
      "id": "chat-helper@koudai.xin",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "messagesRead",
    "tabs",
    "storage",
    "https://koudai.xin/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "message_display_action": {
    "default_title": "聊天助手",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-32.png",
    "128": "icons/icon-80.png"
  }
}