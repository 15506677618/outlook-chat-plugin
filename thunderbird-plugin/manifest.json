{
  "manifest_version": 2,
  "name": "AI 邮件助手",
  "version": "2.1.0",
  "description": "AI 驱动的邮件助手，可在独立窗口中与 AI 讨论邮件内容",
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-mail-assistant@koudai.xin",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "messagesRead",
    "accountsRead",
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "message_display_action": {
    "default_title": "AI 邮件助手",
    "default_icon": {
      "16": "icons/icon-v2-16.png",
      "32": "icons/icon-v2-32.png"
    },
    "theme_icons": [
      {
        "light": "icons/icon-v2-16.png",
        "dark": "icons/icon-v2-32.png",
        "size": 16
      },
      {
        "light": "icons/icon-v2-32.png",
        "dark": "icons/icon-v2-32.png",
        "size": 32
      }
    ]
  },
  "compose_action": {
    "default_title": "邮件询价",
    "default_icon": {
      "16": "icons/icon-v2-16.png",
      "32": "icons/icon-v2-32.png"
    },
    "theme_icons": [
      {
        "light": "icons/icon-v2-16.png",
        "dark": "icons/icon-v2-32.png",
        "size": 16
      },
      {
        "light": "icons/icon-v2-32.png",
        "dark": "icons/icon-v2-32.png",
        "size": 32
      }
    ]
  },
  "icons": {
    "16": "icons/icon-v2-16.png",
    "32": "icons/icon-v2-32.png",
    "48": "icons/icon-v2-80.png",
    "128": "icons/icon-v2-80.png"
  }
}
